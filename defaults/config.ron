#![enable(implicit_some)]
// SPDX-License-Identifier: GPL-3.0-only
// monotile default configuration
// https://github.com/user/monotile

// RON syntax:
// https://github.com/ron-rs/ron

(
    // Output rules: top-to-bottom, later rules override earlier ones.
    outputs: [
        (match: (), scale: 1.0, background: "#444444"),
        // all available fields:
        // (
        //     match: (name: "DP-1", make: "Dell", model: "U2723QE", serial: "ABC123"),
        //     scale: 2.0,
        //     pos: (0, 0),
        //     mode: (size: (2560, 1440), refresh: 144),
        //     transform: Normal,
        //     background: "#222222",
        // ),
    ],

    // Tiling layout and tag settings.
    layout: (
        tags: 9,
        
        inner_gap: 4,
        outer_gap: 2,
        smart_gaps: false,
        smart_borders: false,

        default: Tile,
        tile: (
            main_factor: 0.54,
            main_count: 1,
        ),
    ),

    // Window rules: top-to-bottom, later rules override earlier ones.
    // - init is evaluated once when a window maps (fields override)
    // - render defines the per-window render pipeline and is re-evaluated 
    //   on window state change (entire render pipeline overrides)
    windows: [
        (   // tiled defaults, match all
            match: (),
            render: [
                WindowSurface(fill: "#000000"),
                Border(width: 2, color: "#444444"),
                FocusRing(width: 2, color: "#458588"),
            ],
        ),
        (   // floating overrides
            match: (floating: true),
            render: [
                Shadow(softness: 25, spread: 5, offset: (0, 5), color: "#00000073"),
                WindowSurface(radius: 6.0, fill: "#000000"),
                Border(width: 2, color: "#444444"),
                FocusRing(width: 2, color: "#458588"),
            ],
        ),
        // examples (match strings are auto-anchored regex):
        // (   // browser picture-in-picture: float in bottom-right corner
        //     match: (app_id: "firefox|chromium", title: "Picture.in.[Pp]icture"),
        //     init: (floating: true, size: (480, 270), position: (1400, 770)),
        // ),
        // (   // music on tag 8
        //     match: (app_id: "spotify"),
        //     init: (tags: [8]),
        // ),
        //
        // all available fields:
        // (
        //     match: (app_id: "firefox", title: ".*YouTube.*", floating: true),
        //     init: (
        //         floating: true,
        //         size: (600, 400),
        //         position: (30, 30),
        //         output: "DP-1",
        //         tags: [0, 1, 2],
        //     ),
        //     render: [
        //         Shadow(softness: 25, spread: 5, offset: (0, 5), color: "#00000073"),
        //         WindowSurface(radius: 6.0, fill: "#000000"),
        //         Border(width: 2, color: "#444444"),
        //         FocusRing(width: 2, color: "#458588"),
        //     ],
        // ),
    ],

    // Input devices and cursor behavior.
    input: (
        focus_follows_cursor: true,
        hide_cursor_when_typing: true,
        cursor_warp: false,
        cursor_theme: "default",
        cursor_size: 24,

        keyboard: (
            layout: "de",
            variant: "nodeadkeys",
            options: "",
            repeat_rate: 30,
            repeat_delay: 300,
        ),

        touchpad: (
            accel_profile: Adaptive,
            accel_speed: 0.4,
            natural_scroll: true,
            left_handed: false,
            middle_emulation: false,
            tap: true,
            tap_and_drag: true,
            drag_lock: true,
            disable_while_typing: true,
        ),

        mouse: (
            accel_profile: Flat,
            accel_speed: 0.0,
            natural_scroll: false,
            left_handed: false,
            middle_emulation: false,
        ),
    ),

    // Keyboard shortcuts: ([modifiers], "key", Action).
    keybinds: [
    ([Logo],            "Left",                  Focus(Prev)),
    ([Logo],            "Right",                 Focus(Next)),
    ([Logo, Shift],     "Left",                  Swap(Prev)),
    ([Logo, Shift],     "Right",                 Swap(Next)),
    ([Logo, Shift],     "z",                     Swap(First)),
    ([Logo],            "space",                 ToggleFullscreen),
    ([Logo, Shift],     "space",                 ToggleFloat),
    ([Logo],            "plus",                  AdjustMainCount(1)),
    ([Logo],            "minus",                 AdjustMainCount(-1)),
    ([Logo, Alt],       "Left",                  AdjustMainRatio(-0.01)),
    ([Logo, Alt],       "Right",                 AdjustMainRatio(0.01)),
    ([Logo],            "comma",                 FocusOutput(Left)),
    ([Logo],            "period",                FocusOutput(Right)),
    ([Logo, Shift],     "less",                  SendToOutput(Left)),
    ([Logo, Shift],     "greater",               SendToOutput(Right)),
    ([Logo, Shift],     "q",                     Close),
    ([Logo, Shift],     "r",                     ReloadConfig),
    ([Ctrl, Alt],       "BackSpace",             Exit),

    ([Logo],            "Return",                Spawn(["foot"])),
    ([Logo],            "d",                     Spawn(["fuzzel"])),
    ([Logo],            "w",                     Spawn(["firefox"])),
    ([Logo],            "f",                     Spawn(["nautilus"])),
    ([Logo],            "v",                     Spawn(["/bin/sh", "-c", "cliphist list | fuzzel -d | cliphist decode | wl-copy"])),
    ([Logo],            "l",                     Spawn(["swaylock"])),
    ([Logo, Shift],     "l",                     Spawn(["systemctl", "suspend"])),
    ([Logo, Shift],     "e",                     Spawn(["/bin/sh", "-c", "sel=$(printf 'lock\\nsuspend\\nreboot\\nshutdown' | fuzzel -d -p 'Power: ') && case $sel in lock) swaylock;; suspend) systemctl suspend;; reboot) systemctl reboot;; shutdown) systemctl poweroff;; esac"])),

    ([],                "XF86AudioMute",         Spawn(["wpctl", "set-mute", "@DEFAULT_AUDIO_SINK@", "toggle"])),
    ([],                "XF86AudioLowerVolume",  Spawn(["wpctl", "set-volume", "@DEFAULT_AUDIO_SINK@", "5%-"])),
    ([],                "XF86AudioRaiseVolume",  Spawn(["wpctl", "set-volume", "@DEFAULT_AUDIO_SINK@", "5%+"])),
    ([],                "XF86AudioMicMute",      Spawn(["wpctl", "set-mute", "@DEFAULT_AUDIO_SOURCE@", "toggle"])),
    ([],                "XF86AudioPlay",         Spawn(["playerctl", "play-pause"])),
    ([],                "XF86AudioNext",         Spawn(["playerctl", "next"])),
    ([],                "XF86AudioPrev",         Spawn(["playerctl", "previous"])),
    ([],                "XF86MonBrightnessDown", Spawn(["brightnessctl", "set", "5%-"])),
    ([],                "XF86MonBrightnessUp",   Spawn(["brightnessctl", "set", "5%+"])),
    ([],                "XF86Display",           Noop),
    ([],                "XF86WLAN",              Noop),
    ([],                "XF86Tools",             Noop),
    ([],                "XF86Bluetooth",         Noop),
    ([],                "XF86Keyboard",          Noop),
    ([],                "XF86Favorites",         Noop),
    ([],                "Print",                 Spawn(["/bin/sh", "-c", "grim -g \"$(slurp)\" - | wl-copy"])),
    ([Logo],            "Print",                 Spawn(["/bin/sh", "-c", "grim - | wl-copy"])),

    ([Logo],            "Tab",                   FocusPrevTag),
    ([Logo],              "1",                   FocusTag(0)),
    ([Logo],              "2",                   FocusTag(1)),
    ([Logo],              "3",                   FocusTag(2)),
    ([Logo],              "4",                   FocusTag(3)),
    ([Logo],              "5",                   FocusTag(4)),
    ([Logo],              "6",                   FocusTag(5)),
    ([Logo],              "7",                   FocusTag(6)),
    ([Logo],              "8",                   FocusTag(7)),
    ([Logo],              "9",                   FocusTag(8)),
    ([Logo, Shift],       "1",                   SetTag(0)),
    ([Logo, Shift],       "2",                   SetTag(1)),
    ([Logo, Shift],       "3",                   SetTag(2)),
    ([Logo, Shift],       "4",                   SetTag(3)),
    ([Logo, Shift],       "5",                   SetTag(4)),
    ([Logo, Shift],       "6",                   SetTag(5)),
    ([Logo, Shift],       "7",                   SetTag(6)),
    ([Logo, Shift],       "8",                   SetTag(7)),
    ([Logo, Shift],       "9",                   SetTag(8)),
    ([Logo, Ctrl, Shift], "1",                   ToggleTag(0)),
    ([Logo, Ctrl, Shift], "2",                   ToggleTag(1)),
    ([Logo, Ctrl, Shift], "3",                   ToggleTag(2)),
    ([Logo, Ctrl, Shift], "4",                   ToggleTag(3)),
    ([Logo, Ctrl, Shift], "5",                   ToggleTag(4)),
    ([Logo, Ctrl, Shift], "6",                   ToggleTag(5)),
    ([Logo, Ctrl, Shift], "7",                   ToggleTag(6)),
    ([Logo, Ctrl, Shift], "8",                   ToggleTag(7)),
    ([Logo, Ctrl, Shift], "9",                   ToggleTag(8)),
    ],

    // Mouse button actions on windows: ([modifiers], Button, Action).
    mousebinds: [
    ([Logo],            Left,                    Move),
    ([Logo],            Middle,                  ToggleFloating),
    ([Logo],            Right,                   Resize),
    ],
)

// vim: set autoindent expandtab tabstop=4 shiftwidth=4 :
